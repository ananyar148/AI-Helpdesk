    },
    {
      subject: 'Leave request not being processed',
      description: 'I submitted my annual leave request two weeks ago but it still shows as pending. My manager has already verbally approved it.',
      category: 'HR',
      assignedTeam: 'HR',
      priority: 'Medium',
