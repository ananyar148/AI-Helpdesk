            { icon: '🤖', title: 'AI Classification', desc: 'Auto-routed to the right team' },
            { icon: '⚡', title: 'Fast Response', desc: 'Draft response generated instantly' },
            { icon: '🔒', title: 'Secure', desc: 'Your data is protected' },
